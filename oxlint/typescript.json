{
  "plugins": ["typescript"],
  "jsPlugins": [{ "name": "kubit", "specifier": "../lib/index.js" }],
  "rules": {
    "typescript/no-non-null-assertion": "error",
    "typescript/no-explicit-any": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/ban-ts-comment": [
      "error",
      { "ts-expect-error": "allow-with-description" }
    ],
    "typescript/no-empty-function": "error",
    "typescript/no-shadow": "error",
    "typescript/no-use-before-define": ["error", { "functions": false }],
    "typescript/no-magic-numbers": ["warn", { "ignoreTypeIndexes": true }],
    "kubit/no-public-field-interface": "error"
  }
}
